#  ===========================================================
#  DWM-STYLE CONFIGURATION
#  Modifier: Alt (Option) is used instead of Cmd (Super) 
#  to avoid conflicts with macOS system shortcuts.
#  ===========================================================

# --- System & Applications ---

# Restart Yabai/SKHD (Useful for reloading config)
# DWM Equivalent: Quit/Restart
alt + shift - q : yabai --restart-service && skhd --restart-service

# Terminal (Mod + Return)
# Assumes Alacritty is installed in /Applications
alt - return : open -n /Applications/Alacritty.app

# Launcher (Mod + Shift + Return) -> dmenu_run
# Uses built-in Spotlight (cmd+space) or launch a specific runner
# If you use Raycast/Alfred, replace the command below.
alt + shift - return : open -a "Spotlight"

# Browser (Mod + Alt + f) -> firefox
alt + shift - f : open -a "Firefox"

# --- Window Focus (Stack Navigation) ---

# Focus Next (Mod + j)
alt - j : yabai -m window --focus next || yabai -m window --focus first

# Focus Prev (Mod + k)
alt - k : yabai -m window --focus prev || yabai -m window --focus last

# --- Window Movement (Stack Rotation) ---

# Rotatestack
alt + shift - j : yabai -m window --warp next || yabai -m window --warp first
alt + shift - k : yabai -m window --warp prev || yabai -m window --warp last

# Kill Client (Mod + Shift + c)
alt + shift - c : yabai -m window --close

# --- Layout Management ---

# Resize Master (Mod + h/l) -> setmfact
# Note: Yabai resize is directional, not master-based. 
# This logic tries to expand/shrink based on split.
alt - h : yabai -m window --resize left:-20:0 || yabai -m window --resize right:-20:0
alt - l : yabai -m window --resize right:20:0 || yabai -m window --resize left:20:0

# Float Window (Mod + Shift + f) -> togglefloating
alt + shift - space : yabai -m window --toggle float --grid 4:4:1:1:2:2

# Make window Fullscreen (Mod + Return in DWM zooms, here we toggle zoom)
alt + shift - m : yabai -m window --toggle zoom-fullscreen

# Set Layouts
# Mod + t -> Tile (BSP)
alt - t : yabai -m space --layout bsp
# Mod + f -> Floating
alt - f : yabai -m space --layout float
# Mod + m -> Monocle (Stack)
alt - m : yabai -m space --layout stack

# Balance/Equalize windows (Optional, handy for bsp)
alt - e : yabai -m space --balance

# --- Tag/Space Switching ---
# NOTE: You must create spaces 1-9 in Mission Control manually first.

# View Tag (Mod + 1..9)
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9

# Move Window to Tag (Mod + Shift + 1..9)
alt + shift - 1 : yabai -m window --space 1
alt + shift - 2 : yabai -m window --space 2
alt + shift - 3 : yabai -m window --space 3
alt + shift - 4 : yabai -m window --space 4
alt + shift - 5 : yabai -m window --space 5
alt + shift - 6 : yabai -m window --space 6
alt + shift - 7 : yabai -m window --space 7
alt + shift - 8 : yabai -m window --space 8
alt + shift - 9 : yabai -m window --space 9
