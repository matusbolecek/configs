#!/bin/bash

# Options
OPTIONS="Poweroff\nRestart\nHibernate\nLogout\nCancel"

# Show dmenu
CHOICE=$(echo -e "$OPTIONS" | dmenu -i -p "Power Menu:" "$@")

case "$CHOICE" in
    Poweroff)
        systemctl poweroff
        ;;
    Restart)
        systemctl reboot
        ;;
    Hibernate)
        systemctl hibernate
        notify-send "Hibernate not configured yet" 2>/dev/null || echo "Hibernate not configured"
        ;;
    Logout)
        killall dwm
        ;;
    *)
        # Cancel or dmenu closed — do nothing
        ;;
esac
